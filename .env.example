# Copy this file to .env and fill in your values
# On Railway: Project → Your service → Variables (not this file)

# Required: OpenRouter API key for all LLM calls
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Required for Railway: stable JWT secret so tokens survive restarts
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-here

# Optional: override the default model used for all LLM calls
# DEFAULT_MODEL=openai/gpt-4o-mini
